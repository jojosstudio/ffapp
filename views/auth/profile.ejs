<!DOCTYPE html>
<html lang="de">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/navbar') %>
    
    <main class="main-container">
        <%- include('../partials/flash') %>
        
        <div class="dashboard-welcome">
            <h1>Profil bearbeiten</h1>
            <p>Verwalte deine persönlichen Daten</p>
        </div>
        
        <div class="grid grid-2">
            <div class="card">
                <h3 style="margin-bottom: 1.5rem;">Profilinformationen</h3>
                
                <form action="/profile" method="POST">
                    <div class="form-group">
                        <label class="form-label" for="realname">Vollständiger Name</label>
                        <input type="text" 
                               id="realname" 
                               name="realname" 
                               class="form-input" 
                               value="<%= user.realname %>"
                               required>
                        <small style="color: var(--text-muted); font-size: 0.8rem;">
                            Nur für interne Ranglisten sichtbar
                        </small>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="nickname">Nickname (öffentlich)</label>
                        <input type="text" 
                               id="nickname" 
                               name="nickname" 
                               class="form-input" 
                               value="<%= user.nickname %>"
                               required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="email">E-Mail</label>
                        <input type="email" 
                               id="email" 
                               name="email" 
                               class="form-input" 
                               value="<%= user.email %>"
                               required>
                    </div>
                    
                    <button type="submit" class="btn btn-primary">
                        Änderungen speichern
                    </button>
                </form>

                <div class="form-group" style="margin-top: 1.5rem;">
                    <label class="form-label">Löschzug</label>
                    <div style="padding: 0.75rem; background: var(--glass-bg); border-radius: var(--radius-sm);">
                        <% if (user.role === 'leitstelle') { %>
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <span style="font-size: 1.5rem;">🏛️</span>
                                <div>
                                    <strong>Leitstelle — <%= user.assigned_city_name || 'Stadt nicht zugewiesen' %></strong>
                                    <br><small style="color: var(--text-muted);">Verwaltung aller Löschzüge dieser Stadt</small>
                                </div>
                            </div>
                        <% } else if (user.station_name) { %>
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <span style="font-size: 1.5rem;">🚒</span>
                                <div>
                                    <strong>LZ <%= user.lz_number %> <%= user.station_name %></strong>
                                    <br><small style="color: var(--text-muted);"><%= user.city_name %>, Nordrhein-Westfalen</small>
                                </div>
                            </div>
                            <small style="color: var(--text-muted); font-size: 0.8rem; display: block; margin-top: 0.5rem;">
                                Der Löschzug kann nur durch einen Zugführer geändert werden.
                            </small>
                        <% } else { %>
                            <div style="color: var(--warning); margin-bottom: 0.5rem;">
                                <strong>⚠️ Kein Löschzug zugewiesen</strong>
                            </div>
                            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.75rem;">
                                Du wurdest aus deinem Löschzug entfernt oder hast noch keinen. Du kannst dich bei einem neuen Löschzug bewerben oder deinen Account deaktivieren.
                            </p>

                            <% 
                            const pendingApps = (stationApplications || []).filter(a => a.status === 'pending');
                            const pastApps = (stationApplications || []).filter(a => a.status !== 'pending');
                            const pendingStationIds = pendingApps.map(a => a.station_id);
                            %>

                            <% if (pendingApps.length > 0) { %>
                                <div style="margin-bottom: 1rem;">
                                    <strong style="font-size: 0.85rem;">⏳ Ausstehende Bewerbungen</strong>
                                    <% pendingApps.forEach(app => { %>
                                        <div style="margin-top: 0.5rem; padding: 0.6rem 0.75rem; background: rgba(255, 193, 7, 0.1); border: 1px solid rgba(255, 193, 7, 0.3); border-radius: var(--radius-sm);">
                                            <div style="display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                                                <div>
                                                    <strong>LZ <%= app.lz_number %> <%= app.station_name %></strong>
                                                    <br><small style="color: var(--text-muted);"><%= app.city_name %></small>
                                                </div>
                                                <span style="font-size: 0.75rem; padding: 0.2rem 0.5rem; background: #ffc107; color: #000; border-radius: 999px; font-weight: 600;">
                                                    Ausstehend
                                                </span>
                                            </div>
                                            <small style="color: var(--text-muted); display: block; margin-top: 0.35rem;">
                                                Gesendet am <%= new Date(app.created_at).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                            </small>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } %>

                            <% if (pastApps.length > 0) { %>
                                <div style="margin-bottom: 1rem;">
                                    <strong style="font-size: 0.85rem;">📋 Bewerbungsverlauf</strong>
                                    <% pastApps.forEach(app => { %>
                                        <% 
                                        let statusLabel = 'Unbekannt';
                                        let statusColor = 'var(--text-muted)';
                                        let statusBg = 'var(--glass-bg)';
                                        if (app.status === 'accepted') {
                                            statusLabel = 'Angenommen';
                                            statusColor = '#28a745';
                                            statusBg = 'rgba(40, 167, 69, 0.1)';
                                        } else if (app.status === 'rejected') {
                                            statusLabel = 'Abgelehnt';
                                            statusColor = '#dc3545';
                                            statusBg = 'rgba(220, 53, 69, 0.1)';
                                        } else if (app.status === 'revoked') {
                                            statusLabel = 'Widerrufen';
                                            statusColor = 'var(--text-muted)';
                                        }
                                        %>
                                        <div style="margin-top: 0.5rem; padding: 0.6rem 0.75rem; background: <%= statusBg %>; border: 1px solid var(--glass-border); border-radius: var(--radius-sm);">
                                            <div style="display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                                                <div>
                                                    <strong>LZ <%= app.lz_number %> <%= app.station_name %></strong>
                                                    <br><small style="color: var(--text-muted);"><%= app.city_name %></small>
                                                </div>
                                                <span style="font-size: 0.75rem; padding: 0.2rem 0.5rem; color: <%= statusColor %>; border: 1px solid <%= statusColor %>; border-radius: 999px; font-weight: 600;">
                                                    <%= statusLabel %>
                                                </span>
                                            </div>
                                            <small style="color: var(--text-muted); display: block; margin-top: 0.35rem;">
                                                Beworben: <%= new Date(app.created_at).toLocaleDateString('de-DE') %>
                                                <% if (app.responded_at) { %>
                                                    · Entscheidung: <%= new Date(app.responded_at).toLocaleDateString('de-DE') %>
                                                <% } %>
                                            </small>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } %>

                            <form action="/admin/request-transfer" method="POST" style="margin-top: 0.5rem;">
                                <div class="form-group">
                                    <label class="form-label" style="font-size: 0.85rem;">Bei Löschzug bewerben:</label>
                                    <select name="targetStationId" class="form-select" required>
                                        <option value="">-- Löschzug auswählen --</option>
                                        <% states.forEach(state => { %>
                                            <% state.cities.forEach(city => { %>
                                                <% if (city.stations && city.stations.length > 0) { %>
                                                    <% city.stations.forEach(station => { %>
                                                        <% if (!pendingStationIds.includes(station.id)) { %>
                                                            <option value="<%= station.id %>">
                                                                LZ <%= station.lz_number %> <%= station.name %> (<%= city.name %>)
                                                            </option>
                                                        <% } %>
                                                    <% }); %>
                                                <% } %>
                                            <% }); %>
                                        <% }); %>
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 0.5rem;">
                                    📨 Bewerbung senden
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            </div>
            
            <div class="card">
                <h3 style="margin-bottom: 1.5rem;">Passwort ändern</h3>
                
                <form action="/profile" method="POST">
                    <div class="form-group">
                        <label class="form-label" for="current_password">Aktuelles Passwort</label>
                        <input type="password" 
                               id="current_password" 
                               name="current_password" 
                               class="form-input" 
                               placeholder="Aktuelles Passwort">
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="new_password">Neues Passwort</label>
                        <input type="password" 
                               id="new_password" 
                               name="new_password" 
                               class="form-input" 
                               placeholder="Mindestens 6 Zeichen"
                               minlength="6">
                    </div>
                    
                    <button type="submit" class="btn btn-secondary">
                        Passwort ändern
                    </button>
                </form>
                
                <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--glass-border);">
                    <h4 style="margin-bottom: 1rem;">Account-Info</h4>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.5rem;">
                        <strong>Rolle:</strong> 
                        <% if (user.role === 'super_admin') { %>Super Admin<% }
                        else if (user.role === 'leitstelle') { %>Leitstelle<% }
                        else if (user.role === 'zugfuehrer') { %>Zugführer<% }
                        else if (user.role === 'jf') { %>Jugendfeuerwehr<% }
                        else { %>Einsatzabteilung<% } %>
                    </p>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.5rem;">
                        <strong>Punkte (aktuelle Saison):</strong> <%= user.points %>
                    </p>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.5rem;">
                        <strong>Punkte (gesamt):</strong> 
                        <span style="color: var(--ff-red-light); font-weight: 700; font-size: 1.1rem;">
                            <%= totalAllTime %>
                        </span>
                        <small style="color: var(--text-muted);">alle Challenges aller Zeiten</small>
                    </p>
                    <p style="color: var(--text-secondary); font-size: 0.9rem;">
                        <strong>Mitglied seit:</strong> <%= new Date(user.created_at).toLocaleDateString('de-DE') %>
                    </p>
                </div>

                <!-- Season History -->
                <% if (seasonHistory && seasonHistory.length > 0) { %>
                <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--glass-border);">
                    <h4 style="margin-bottom: 1rem;">📅 Season-Verlauf</h4>
                    <div style="max-height: 300px; overflow-y: auto;">
                        <% seasonHistory.forEach(sh => { %>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem; background: var(--glass-bg); border-radius: var(--radius-sm); margin-bottom: 0.5rem;">
                                <div>
                                    <strong><%= sh.season_name %></strong>
                                    <br><small style="color: var(--text-muted); font-size: 0.8rem;">
                                        <%= new Date(sh.start_date).toLocaleDateString('de-DE') %> – <%= new Date(sh.end_date).toLocaleDateString('de-DE') %>
                                    </small>
                                </div>
                                <div style="text-align: right;">
                                    <span style="font-weight: 700; color: var(--ff-red-light);">
                                        +<%= sh.points_earned %> Punkte
                                    </span>
                                    <% if (sh.rank_position) { %>
                                        <br><small style="color: var(--text-muted); font-size: 0.8rem;">
                                            Platz #<%= sh.rank_position %>
                                        </small>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
                <% } %>

                <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--glass-border);">
                    <h4 style="margin-bottom: 1rem; color: var(--ff-red);">Gefahrenbereich</h4>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
                        Das Deaktivieren deines Accounts kann nicht rückgängig gemacht werden.
                    </p>
                    <form action="/profile/deactivate" method="POST" onsubmit="return confirm('Bist du sicher, dass du deinen Account deaktivieren möchtest? Diese Aktion kann nicht rückgängig gemacht werden.');">
                        <button type="submit" class="btn" style="width: 100%; background: var(--ff-red); color: white;">
                            ❌ Account deaktivieren
                        </button>
                    </form>
                </div>
            </div>
        </div>
</main>
</body>
</html>
