<!DOCTYPE html>
<html lang="de">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/navbar') %>
    
    <main class="main-container">
        <%- include('../partials/flash') %>
        
        <div class="auth-container" style="max-width: 500px;">
            <div class="card auth-card">
                <div style="text-align: center; margin-bottom: 1.5rem;">
                    <span style="font-size: 3rem;">📨</span>
                    <h1 class="auth-title" style="margin-top: 0.5rem;">Einladung annehmen</h1>
                </div>
                
                <div style="background: var(--glass-bg); border-radius: var(--radius-md); padding: 1.25rem; margin-bottom: 1.5rem;">
                    <h4 style="margin-bottom: 0.75rem;">👤 Deine Daten</h4>
                    <p><strong>Name:</strong> <%= invitation.realname %></p>
                    <p><strong>Nickname:</strong> <%= invitation.nickname %></p>
                    <p><strong>Rolle:</strong> 
                        <% if (invitation.role === 'jf') { %>🌟 Jugendfeuerwehr
                        <% } else if (invitation.role === 'zugfuehrer') { %>🚒 Zugführer
                        <% } else { %>🔥 Einsatzabteilung<% } %>
                    </p>
                    <p><strong>Feuerwache:</strong> LZ <%= invitation.lz_number %> <%= invitation.station_name %>, <%= invitation.city_name %></p>
                </div>
                
                <p style="margin-bottom: 1.5rem; color: var(--text-secondary);">
                    Lege jetzt deine E-Mail und dein persönliches Passwort fest, 
                    um deinen Account zu aktivieren.
                </p>
                
                <form action="/einladung/<%= token %>" method="POST">
                    <div class="form-group">
                        <label class="form-label" for="email">📧 Deine E-Mail *</label>
                        <input type="email" id="email" name="email" class="form-input" 
                               placeholder="deine.email@beispiel.de" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="password">🔒 Passwort *</label>
                        <input type="password" id="password" name="password" class="form-input" 
                               placeholder="Mindestens 6 Zeichen" minlength="6" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="password_confirm">🔒 Passwort bestätigen *</label>
                        <input type="password" id="password_confirm" name="password_confirm" class="form-input" 
                               placeholder="Passwort wiederholen" required>
                    </div>
                    
                    <button type="submit" class="btn btn-primary" style="width: 100%; font-size: 1.1rem; padding: 1rem;">
                        🚒 Account aktivieren
                    </button>
                </form>
            </div>
        </div>
    </main>
</body>
</html>