<!DOCTYPE html>
<html lang="de">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/navbar') %>
    
    <main class="main-container">
        <%- include('../partials/flash') %>
        
        <div class="card" style="margin-bottom: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                <span class="challenge-type <%= challenge.type %>">
                    <%= challenge.type === 'theorie' ? '📚 Theorie' : '🎯 Praxis' %>
                </span>
                <% if (challenge.target_group !== 'both') { %>
                    <span class="badge badge-<%= challenge.target_group === 'jf' ? 'blue' : 'green' %>">
                        <%= challenge.target_group.toUpperCase() %>
                    </span>
                <% } %>
                <% if (completed) { %>
                    <span class="badge badge-green">✓ Abgeschlossen</span>
                <% } %>
            </div>
            
            <h1 style="margin-bottom: 0.5rem;"><%= challenge.title %></h1>
            <p style="color: var(--text-secondary); margin-bottom: 1rem;"><%= challenge.description %></p>
            
            <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
                <span class="points-badge">🏆 <%= challenge.points %> Punkte</span>
                <span style="color: var(--text-muted);">📝 <%= challenge.question_count %> Fragen</span>
            </div>
        </div>
        
        <% if (completed) { %>
            <div class="card" style="text-align: center; padding: 2rem;">
                <p style="color: var(--success); font-size: 1.25rem; margin-bottom: 1rem;">
                    ✓ Du hast diese Challenge bereits abgeschlossen!
                </p>
                <a href="/challenges" class="btn btn-primary">Weitere Challenges</a>
            </div>
        <% } else if (!canRetry) { %>
            <div class="card" style="text-align: center; padding: 2rem; border: 2px solid var(--warning);">
                <span style="font-size: 3rem; display: block; margin-bottom: 1rem;">⏳</span>
                <h3 style="margin-bottom: 1rem;">Wartezeit aktiv</h3>
                <p style="color: var(--text-secondary); margin-bottom: 1rem;">
                    Du musst noch <strong><%= cooldownRemaining.hours %> Stunden und <%= cooldownRemaining.minutes %> Minuten</strong> warten
                </p>
                <a href="/challenges" class="btn btn-primary">Andere Challenges</a>
            </div>
        <% } else if (challenge.type === 'theorie') { %>
            <!-- Quiz: ONE QUESTION AT A TIME -->
            <div class="card quiz-container">
                <h3 style="margin-bottom: 1rem;">📝 Quiz</h3>
                
                <!-- Progress Bar -->
                <div class="quiz-progress-bar">
                    <div class="quiz-progress-fill" id="progressFill" style="width: <%= 100/challenge.questions.length %>%"></div>
                </div>
                <div class="quiz-counter" id="quizCounter">Frage 1 von <%= challenge.questions.length %></div>
                
                <form id="quizForm" action="/challenges/<%= challenge.id %>/submit-quiz" method="POST">
                    <% challenge.questions.forEach((q, index) => { %>
                        <div class="quiz-question-card <%= index === 0 ? 'active' : '' %>" data-question="<%= index %>">
                            <p style="font-weight: 600; font-size: 1.1rem; margin-bottom: 1.5rem;">
                                <span style="color: var(--ff-red);"><%= index + 1 %>.</span> <%= q.question %>
                            </p>
                            
                            <% const letters = ['A', 'B', 'C', 'D']; %>
                            <% q.options.forEach((option, optIndex) => { %>
                                <label class="quiz-option" onclick="selectOption(this, <%= index %>, <%= optIndex %>)">
                                    <input type="radio" name="answers[<%= index %>]" value="<%= optIndex %>">
                                    <span class="option-letter"><%= letters[optIndex] || optIndex + 1 %></span>
                                    <span class="option-text"><%= option %></span>
                                </label>
                            <% }); %>
                        </div>
                    <% }); %>
                    
                    <!-- Navigation -->
                    <div class="quiz-nav" id="quizNav">
                        <button type="button" class="btn btn-secondary" id="prevBtn" onclick="prevQuestion()" disabled>← Zurück</button>
                        <span id="questionIndicator" style="color: var(--text-muted); font-size: 0.85rem;">1 / <%= challenge.questions.length %></span>
                        <button type="button" class="btn btn-primary" id="nextBtn" onclick="nextQuestion()">Weiter →</button>
                    </div>
                    
                    <!-- Submit Area (visible on last question) -->
                    <div class="quiz-submit-area" id="submitArea" style="display: none;">
                        <p style="color: var(--text-muted); margin-bottom: 1rem;">
                            ✅ Alle Fragen beantwortet! Jetzt abschicken.
                        </p>
                        <button type="submit" class="btn btn-primary btn-lg" style="width: 100%;">
                            🏆 Quiz absenden & Punkte sichern!
                        </button>
                    </div>
                </form>
            </div>
            
            <script>
                const totalQuestions = <%= challenge.questions.length %>;
                let currentQuestion = 0;
                const answers = {};
                
                function selectOption(el, qIndex, optIndex) {
                    // Remove selected from siblings
                    const parent = el.parentElement;
                    parent.querySelectorAll('.quiz-option').forEach(o => o.classList.remove('selected'));
                    el.classList.add('selected');
                    // Check the radio
                    const radio = el.querySelector('input[type="radio"]');
                    if (radio) radio.checked = true;
                    answers[qIndex] = optIndex;
                    updateNav();
                }
                
                function showQuestion(index) {
                    document.querySelectorAll('.quiz-question-card').forEach(c => c.classList.remove('active'));
                    const card = document.querySelector(`.quiz-question-card[data-question="${index}"]`);
                    if (card) card.classList.add('active');
                    
                    currentQuestion = index;
                    const pct = ((index + 1) / totalQuestions) * 100;
                    document.getElementById('progressFill').style.width = pct + '%';
                    document.getElementById('quizCounter').textContent = `Frage ${index + 1} von ${totalQuestions}`;
                    document.getElementById('questionIndicator').textContent = `${index + 1} / ${totalQuestions}`;
                    
                    document.getElementById('prevBtn').disabled = index === 0;
                    
                    const isLast = index === totalQuestions - 1;
                    document.getElementById('nextBtn').style.display = isLast ? 'none' : 'inline-block';
                    document.getElementById('submitArea').style.display = isLast ? 'block' : 'none';
                }
                
                function nextQuestion() {
                    if (currentQuestion < totalQuestions - 1) {
                        showQuestion(currentQuestion + 1);
                    }
                }
                
                function prevQuestion() {
                    if (currentQuestion > 0) {
                        showQuestion(currentQuestion - 1);
                    }
                }
                
                function updateNav() {
                    const answered = Object.keys(answers).length;
                    document.getElementById('nextBtn').textContent = answered > currentQuestion ? 'Weiter →' : 'Überspringen →';
                }
                
                // Prevent form submit if not all answered
                document.getElementById('quizForm').addEventListener('submit', function(e) {
                    const unanswered = totalQuestions - Object.keys(answers).length;
                    if (unanswered > 0) {
                        e.preventDefault();
                        if (confirm(`⚠️ Du hast ${unanswered} Frage(n) nicht beantwortet. Trotzdem absenden?`)) {
                            this.submit();
                        }
                    }
                });
            </script>
        <% } else { %>
            <!-- Practice Form (unchanged) -->
            <div class="card">
                <h3 style="margin-bottom: 1.5rem;">Aufgabe einreichen</h3>
                <form action="/challenges/<%= challenge.id %>/submit-practice" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <label class="form-label">Beschreibung (optional)</label>
                        <textarea name="description" class="form-textarea" placeholder="Beschreibe kurz, wie du die Aufgabe erfüllt hast..."></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Nachweis-Bild *</label>
                        <input type="file" name="proof" accept="image/*" required class="form-input" onchange="document.getElementById('preview').src=URL.createObjectURL(this.files[0]); document.getElementById('preview').style.display='block'">
                        <img id="preview" style="display:none;max-width:100%;margin-top:1rem;border-radius:var(--radius-md);">
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg" style="width:100%">Einreichung absenden</button>
                </form>
            </div>
        <% } %>
    </main>
</body>
</html>