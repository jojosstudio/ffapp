<%- include('../layouts/header') %>

<div class="container my-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h1 class="mb-4">
                <i class="fas fa-qrcode"></i> Einladungs-QR-Codes
            </h1>

            <!-- Statistics -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-muted">Gesamt</h5>
                            <h2 class="text-primary"><%= stats.total || 0 %></h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-muted">Verwendet</h5>
                            <h2 class="text-success"><%= stats.used || 0 %></h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-muted">Widerrufen</h5>
                            <h2 class="text-danger"><%= stats.revoked || 0 %></h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-muted">Abgelaufen</h5>
                            <h2 class="text-warning"><%= stats.expired || 0 %></h2>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Create New Invitations -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-plus"></i> Neue Einladungen erstellen</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="/admin/invitations/create">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="role"><strong>Rolle für Einladung</strong></label>
                                    <select class="form-control" id="role" name="role" required>
                                        <option value="">-- Wähle Rolle --</option>
                                        <option value="ff">Feuerwehrleute (FF)</option>
                                        <option value="jf">Jugendfeuerwehr (JF)</option>
                                    </select>
                                    <small class="text-muted">Die Person wird mit dieser Rolle registriert</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="quantity"><strong>Anzahl</strong></label>
                                    <input type="number" class="form-control" id="quantity" name="quantity" min="1" max="50" value="1" required>
                                    <small class="text-muted">Maximal 50 auf einmal</small>
                                </div>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-plus"></i> Einladungen erstellen
                        </button>
                    </form>
                </div>
            </div>

            <!-- Invitations List -->
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-list"></i> Aktive Einladungen</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Token</th>
                                <th>Rolle</th>
                                <th>Status</th>
                                <th>Erstellt</th>
                                <th>Ablauf</th>
                                <th>Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (invitations && invitations.length > 0) { %>
                                <% invitations.forEach(inv => { %>
                                    <% 
                                        let statusClass = 'warning';
                                        let statusText = 'Ausstehend';
                                        
                                        if (inv.used) {
                                            statusClass = 'success';
                                            statusText = 'Verwendet';
                                        } else if (inv.status === 'revoked') {
                                            statusClass = 'danger';
                                            statusText = 'Widerrufen';
                                        } else if (inv.expires_at && new Date(inv.expires_at) < new Date()) {
                                            statusClass = 'secondary';
                                            statusText = 'Abgelaufen';
                                        }
                                    %>
                                    <tr>
                                        <td>
                                            <code><%= inv.token.substring(0, 16) %>...</code>
                                        </td>
                                        <td>
                                            <span class="badge badge-info">
                                                <%= inv.role === 'ff' ? 'FF' : 'JF' %>
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge badge-<%= statusClass %>">
                                                <%= statusText %>
                                            </span>
                                        </td>
                                        <td>
                                            <%= new Date(inv.created_at).toLocaleDateString('de-DE') %>
                                        </td>
                                        <td>
                                            <% if (inv.expires_at) { %>
                                                <%= new Date(inv.expires_at).toLocaleDateString('de-DE') %>
                                            <% } else { %>
                                                <span class="text-muted">Unbegrenzt</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (!inv.used && inv.status !== 'revoked' && (!inv.expires_at || new Date(inv.expires_at) > new Date())) { %>
                                                <a href="/admin/invitations/qr/<%= inv.token %>" class="btn btn-sm btn-info">
                                                    <i class="fas fa-qrcode"></i> QR-Code
                                                </a>
                                                <form method="POST" action="/admin/invitations/revoke/<%= inv.token %>" style="display: inline;">
                                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('QR-Code wirklich widerrufen?')">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            <% } else { %>
                                                <span class="text-muted">—</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        <i class="fas fa-inbox"></i> Noch keine Einladungen erstellt
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Info Box -->
            <div class="alert alert-info mt-4">
                <h6><i class="fas fa-info-circle"></i> Wie funktioniert das System?</h6>
                <ul class="mb-0">
                    <li>Erstelle QR-Codes mit der Rolle, die neue Mitglieder haben sollen (FF oder JF)</li>
                    <li>Teile den QR-Code mit deinen Mitgliedern (ausdrucken, auf Handy zeigen, etc.)</li>
                    <li>Jeder kann den Code scannen und sich selbst mit Nickname, E-Mail und Passwort registrieren</li>
                    <li>Die Person wird automatisch mit der gewählten Rolle in deinen Löschzug aufgenommen</li>
                    <li>Der QR-Code kann mehrfach verwendet werden, bis du ihn widerrufst oder er abläuft</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<%- include('../layouts/footer') %>
