                                <option value="<%= s.id %>"><%= s.name %></option>
                            <% }); } %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Postleitzahl (PLZ)</label>
                        <input type="text" name="plz" id="plz-input" class="form-input" placeholder="z.B. 10115" required>
                        <small class="form-text mt-1">Postleitzahl angeben (PLZ). Um die Stadt/den Kreis zu bestimmen, wird die PLZ zur Validierung verwendet.</small>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Bundesstadt/Kreis</label>
                        <select id="admin-city" name="city_id" class="form-select" required>
                            <option value="">Bitte wÃĪhlen Sie die Stadt/den Kreis aus</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">LZ-Nummer</label>
                        <input type="number" name="lz_number" class="form-input" placeholder="z.B. 19" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Name</label>
                        <input type="text" name="name" class="form-input" placeholder="z.B. HeÃler" required>
                    </div>
                    <div class="form-group">
                        <label class="form-check" style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                            <input type="checkbox" name="verified" value="1" checked style="width: 20px; height: 20px;">
