<!DOCTYPE html>
<html lang="de">
<head>
    <%- include('../partials/head') %>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    
    <main class="main-container">
        <%- include('../partials/flash') %>
        
        <div class="dashboard-welcome">
            <h1>âĄ Super Admin Dashboard</h1>
            <p>Verwaltung der Feuerwehr-Challenge NRW</p>
        </div>
        
        <!-- Stats Overview -->
        <div class="stats-grid mb-4">
            <div class="card stat-card">
                <span class="stat-value"><%= totalUsers || 0 %></span>
                <span class="stat-label">Nutzer</span>
            </div>
            <div class="card stat-card">
                <span class="stat-value"><%= totalStations || 0 %></span>
                <span class="stat-label">LÃķschzÃžge</span>
            </div>
            <div class="card stat-card">
                <span class="stat-value"><%= totalPoints || 0 %></span>
                <span class="stat-label">Punkte gesamt</span>
            </div>
            <div class="card stat-card">
                <span class="stat-value"><%= pendingSubmissions ? pendingSubmissions.length : 0 %></span>
                <span class="stat-label">Offene PrÃžfungen</span>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="admin-grid mb-4">
            <% if (unverifiedStations && unverifiedStations.length > 0) { %>
            <div class="card admin-card">
                <h3>ð Nicht verifizierte LÃķschzÃžge (<%= unverifiedStations.length %>)</h3>
                <ul class="admin-list" style="max-height: 220px; overflow-y: auto;">
                    <% unverifiedStations.forEach(station => { %>
                        <li class="admin-list-item">
                            <div>
                                <strong>LZ <%= station.lz_number %> <%= station.name %></strong>
                                <br><small style="color: var(--text-muted);"><%= station.city_name %></small>
                            </div>
                            <form action="/admin/verify-station/<%= station.id %>" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-primary btn-sm">Verifizieren</button>
