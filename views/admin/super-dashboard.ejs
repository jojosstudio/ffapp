            </div>
            <% } %>

            <div class="card admin-card">
                <h3>ð Schnellzugriff</h3>
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <a href="/admin/challenges" class="btn btn-secondary" style="text-align: center;">Challenge-Verwaltung</a>
                    <% if (usersWithoutStation > 0) { %>
                        <button type="button" class="btn btn-secondary" onclick="filterNoStation()">
                            <%= usersWithoutStation %> Nutzer ohne LÃķschzug
                        </button>
                    <% } else { %>
                        <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">Alle Nutzer haben einen LÃķschzug zugewiesen.</p>
                    <% } %>
                </div>
            </div>
        </div>
        
        <div class="admin-grid">
            <!-- Create City -->
            <div class="card admin-card">
                <h3>ðïļ Neue Stadt/Kreis hinzufÃžgen</h3>
                <form action="/admin/create-city" method="POST">
                    <div class="form-group">
                        <label class="form-label">Bundesland</label>
                        <select name="state_id" class="form-select" required>
                            <option value="">WÃĪhlen...</option>
                            <% if (states) { states.forEach(s => { %>
                                <option value="<%= s.id %>"><%= s.name %></option>
                            <% }); } %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Name</label>
