            </div>
            
            <!-- Create Station -->
            <div class="card admin-card">
                <h3>ð Neuen LÃķschzug erstellen</h3>
                <form action="/admin/create-station" method="POST">
                    <div class="form-group">
                        <label class="form-label">Bundesland</label>
                        <select id="admin-state" class="form-select" required>
                            <option value="">WÃĪhlen...</option>
