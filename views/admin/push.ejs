<%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/navbar') %>
    
    <main class="main-container">
        <%- include('../partials/flash') %>
        
        <div class="mb-4">
            <a href="/admin/super" class="btn btn-secondary">&larr; Zurück zum Dashboard</a>
        </div>

        <div class="card mb-4">
            <h1 class="section-title">📢 Push-Benachrichtigungen senden</h1>
            <p class="text-secondary mb-3">Sende Push-Benachrichtigungen an alle Nutzer oder an einzelne Stationen.</p>
            
            <form id="pushForm" class="mt-3">
                <div class="form-group">
                    <label class="form-label">Empfänger</label>
                    <select id="targetType" name="targetType" class="form-select" onchange="toggleStationSelect()">
                        <option value="all">🌍 An alle Nutzer</option>
                        <option value="station">🏛️ An eine bestimmte Station</option>
                    </select>
                </div>

                <div class="form-group" id="stationSelectGroup" style="display:none;">
                    <label class="form-label">Station auswählen</label>
                    <select id="stationId" name="stationId" class="form-select">
                        <option value="">-- Station wählen --</option>
                        <% (allStations || []).forEach(station => { %>
                            <option value="<%= station.id %>">
                                <%= station.name %> (LZ <%= station.lz_number %>)
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Titel</label>
                    <input type="text" id="pushTitle" name="title" class="form-input" placeholder="z.B. Neue Challenge verfügbar" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Nachricht</label>
                    <textarea id="pushBody" name="body" class="form-textarea" placeholder="z.B. Es gibt eine neue praktische Challenge für deinen Löschzug!" required></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">Link (optional)</label>
                    <input type="text" id="pushUrl" name="url" class="form-input" value="/dashboard" placeholder="/dashboard">
                </div>

                <button type="submit" class="btn btn-primary btn-lg" id="sendBtn">
                    📨 Senden
                </button>
            </form>

            <div id="resultArea" class="mt-4" style="display:none;"></div>
        </div>

        <div class="card">
            <h2 class="section-title">📊 Push-Statistiken</h2>
            <div class="stats-grid">
                <div class="stat-card glass">
                    <span class="stat-value"><%= subscriptionCount || 0 %></span>
                    <span class="stat-label">Registrierte Geräte</span>
                </div>
                <div class="stat-card glass">
                    <span class="stat-value"><%= userCount || 0 %></span>
                    <span class="stat-label">Aktive Nutzer</span>
                </div>
            </div>
        </div>
    </main>

    <script>
        function toggleStationSelect() {
            const type = document.getElementById('targetType').value;
            document.getElementById('stationSelectGroup').style.display = type === 'station' ? 'block' : 'none';
        }

        document.getElementById('pushForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const btn = document.getElementById('sendBtn');
            const resultArea = document.getElementById('resultArea');
            const title = document.getElementById('pushTitle').value;
            const body = document.getElementById('pushBody').value;
            const url = document.getElementById('pushUrl').value;
            const targetType = document.getElementById('targetType').value;
            const stationId = document.getElementById('stationId').value;

            btn.disabled = true;
            btn.textContent = '⏳ Sende...';

            let endpoint = '/api/push/send-all';
            let payload = { title, body, url };

            if (targetType === 'station') {
                if (!stationId) {
                    alert('Bitte wähle eine Station aus');
                    btn.disabled = false;
                    btn.textContent = '📨 Senden';
                    return;
                }
                endpoint = '/api/push/send-station';
                payload.stationId = stationId;
            }

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (response.ok) {
                    resultArea.style.display = 'block';
                    resultArea.className = 'alert alert-success mt-3';
                    resultArea.innerHTML = `
                        <strong>✅ Erfolgreich gesendet!</strong><br>
                        Gesendet: ${result.successCount || 0} / ${result.total || 0}<br>
                        Fehlgeschlagen: ${result.failCount || 0}
                    `;
                } else {
                    resultArea.style.display = 'block';
                    resultArea.className = 'alert alert-error mt-3';
                    resultArea.innerHTML = `<strong>❌ Fehler:</strong> ${result.error || 'Unbekannter Fehler'}`;
                }
            } catch (error) {
                resultArea.style.display = 'block';
                resultArea.className = 'alert alert-error mt-3';
                resultArea.innerHTML = `<strong>❌ Fehler:</strong> ${error.message}`;
            }

            btn.disabled = false;
            btn.textContent = '📨 Senden';
        });
    </script>

</body>
</html>